<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <!-- Define properties -->
    <PropertyGroup>
        <Alco_AssetsPath Condition="'$(Alco_AssetsPath)' == ''">
            $(MSBuildProjectDirectory)\Assets</Alco_AssetsPath>
        <Alco_AssetsOutputPath Condition="'$(Alco_AssetsOutputPath)' == ''">$(OutputPath)\Assets</Alco_AssetsOutputPath>
    </PropertyGroup>

    <!-- Define targets -->
    <Target Name="CopyAssetsToOutput" AfterTargets="Build"
        Condition="Exists('$(Alco_AssetsPath)')">
        <Message Text="Copying Assets from '$(Alco_AssetsPath)' to '$(Alco_AssetsOutputPath)'"
            Importance="high" />

        <!-- Create the target directory if it doesn't exist -->
        <MakeDir Directories="$(Alco_AssetsOutputPath)"
            Condition="!Exists('$(Alco_AssetsOutputPath)')" />

        <!-- Copy all files from the Assets directory to the output directory -->
        <ItemGroup>
            <AssetFiles Include="$(Alco_AssetsPath)\**\*.*" />
        </ItemGroup>

        <Copy
            SourceFiles="@(AssetFiles)"
            DestinationFiles="@(AssetFiles->'$(Alco_AssetsOutputPath)\%(RecursiveDir)%(Filename)%(Extension)')"
            SkipUnchangedFiles="true" />

        <Message Text="Assets copied successfully." Importance="high" />
    </Target>
</Project> 