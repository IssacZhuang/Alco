<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Alco.Editor.Views.ExplorerPageView">
    <Grid ColumnDefinitions="250,Auto,*,Auto,250">
        <!-- File browser area -->
        <Border Grid.Column="0"
            BorderBrush="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            BorderThickness="0,0,1,0">
            <Grid>
                <!-- Initial state - Open Folder button -->
                <StackPanel x:Name="NoFolderPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10">
                    <TextBlock Text="No folder opened"
                        HorizontalAlignment="Center" />
                    <Button x:Name="OpenFolderButton"
                        Content="Open Folder"
                        Click="OnOpenFolderClick" />
                </StackPanel>

                <!-- File tree view - initially hidden -->
                <TreeView x:Name="FileTreeView"
                    IsVisible="False"
                    DoubleTapped="OnFileTreeViewDoubleTapped" />
            </Grid>
        </Border>

        <!-- Splitter between file browser and edit area -->
        <GridSplitter Grid.Column="1"
            Background="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            ResizeDirection="Columns"
            Width="4" />

        <!-- Edit object area -->
        <Border Grid.Column="2"
            BorderBrush="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            BorderThickness="0,0,1,0">
            <ContentControl x:Name="EditArea" />
        </Border>

        <!-- Splitter between edit area and preview -->
        <GridSplitter Grid.Column="3"
            Background="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            ResizeDirection="Columns"
            Width="4" />

        <!-- Preview area -->
        <Border Grid.Column="4">
            <ContentControl x:Name="PreviewArea" />
        </Border>
    </Grid>
</UserControl> 