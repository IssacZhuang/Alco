<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
  x:Class="Alco.Editor.Views.PropertyDictionaryEditor">
  <Expander HorizontalAlignment="Stretch">
    <Expander.Header>
      <TextBlock x:Name="TextHeader" Text="Dictionary" />
    </Expander.Header>
    <StackPanel Orientation="Vertical">
      <StackPanel Orientation="Horizontal">
        <Button Width="40" x:Name="BtnAdd" Margin="5 0" HorizontalContentAlignment="Center"
          VerticalContentAlignment="Center">+</Button>
      </StackPanel>
      <StackPanel x:Name="Root" Orientation="Vertical" Margin="0 10 0 0" Spacing="10">
      </StackPanel>
    </StackPanel>
  </Expander>
</UserControl> 