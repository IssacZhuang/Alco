<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:Alco.Editor.ViewModels"
  xmlns:views="using:Alco.Editor.Views"
  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
  xmlns:avalonia="https://github.com/avaloniaui/avaloniaedit"
  x:DataType="vm:InspectorForConfig"
  x:Class="Alco.Editor.Views.InspectorForConfig">

  <Design.DataContext>
    <vm:InspectorForConfig />
  </Design.DataContext>

  <Grid ColumnDefinitions="*, 6, *" x:Name="Root">
    <!-- Left Panel with ObjectPropertiesEditor -->
    <StackPanel Orientation="Vertical" Grid.Column="0" x:Name="LeftPanel">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="6">
        <Button x:Name="BtnSave" Click="OnBtnSaveClick">
          <PathIcon Data="{StaticResource Icons.Save}" Width="16" Height="16" />
        </Button>
        <Button x:Name="BtnPlay" Click="OnBtnPlayClick">
          <PathIcon Data="{StaticResource Icons.Action}" Width="16" Height="16" />
        </Button>
      </StackPanel>
      <views:ObjectPropertiesEditor
        x:Name="PropertiesEditor" />
    </StackPanel>

    <!-- GridSplitter -->
    <GridSplitter Grid.Column="1"
      Background="Gray"
      x:Name="GridSplitter"
      DragCompleted="OnGridSplitterDragCompleted"
      ResizeDirection="Columns"
      IsVisible="{Binding IsPreviewEnabled}"
      Width="4" />

    <!-- Right Panel with TextEditor -->
    <StackPanel Orientation="Vertical" Grid.Column="2" x:Name="RightPanel"
      IsVisible="{Binding IsPreviewEnabled}">
      <TextBlock x:Name="TextError" 
       Margin="15 10"
       Foreground="Red"
       IsVisible="False" />
      <TextBlock Text="Json Preview" Margin="15 10" />
      <avalonia:TextEditor
        x:Name="TextJsonPreview"
        ShowLineNumbers="True"
        IsReadOnly="True"
        FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
      HorizontalScrollBarVisibility="Auto"
      VerticalScrollBarVisibility="Auto"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      MinHeight="100"
      MinWidth="100"
      Background="Transparent"
      Foreground="White"
      IsVisible="True">
      <avalonia:TextEditor.Options>
        <avalonia:TextEditorOptions
          ShowBoxForControlCharacters="True"
          EnableHyperlinks="True"
          EnableEmailHyperlinks="True"
          AllowScrollBelowDocument="True"
          EnableTextDragDrop="True"
          EnableImeSupport="True"
          HighlightCurrentLine="True" />
        </avalonia:TextEditor.Options>
      </avalonia:TextEditor>
    </StackPanel>
  </Grid>
</UserControl>