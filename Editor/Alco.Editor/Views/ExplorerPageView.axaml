<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Alco.Editor.Views.ExplorerPageView">
    <Grid ColumnDefinitions="250,Auto,*,Auto,250">
        <!-- File browser area -->
        <Border Grid.Column="0"
            BorderBrush="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            BorderThickness="0,0,1,0">
            <TreeView x:Name="FileTreeView">
                <TreeViewItem Header="项目">
                    <TreeViewItem Header="文件夹 1" />
                    <TreeViewItem Header="文件夹 2" />
                </TreeViewItem>
            </TreeView>
        </Border>

        <!-- Splitter between file browser and edit area -->
        <GridSplitter Grid.Column="1"
            Background="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            ResizeDirection="Columns"
            Width="4" />

        <!-- Edit object area -->
        <Border Grid.Column="2"
            BorderBrush="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            BorderThickness="0,0,1,0">
            <TextBlock Text="Edit area" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Splitter between edit area and preview -->
        <GridSplitter Grid.Column="3"
            Background="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            ResizeDirection="Columns"
            Width="4" />

        <!-- Preview area -->
        <Border Grid.Column="4">
            <TextBlock Text="Preview area" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl> 