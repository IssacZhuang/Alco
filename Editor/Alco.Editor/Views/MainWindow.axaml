<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Alco.Editor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Alco.Editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Alco.Editor">

<Window.Resources>
</Window.Resources>

<Window.Styles>
    <!-- Base Styles -->
    <Style Selector="Menu > MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#D1D1D1"/>
    </Style>

    <!-- Submenu Styles -->
    <Style Selector="MenuItem MenuItem">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <!-- Button Base Styles -->
    <Style Selector="Button">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="PathIcon">
        <Setter Property="Foreground" Value="#D1D1D1"/>
    </Style>

    <!-- Top-level Menu Item Interaction States -->
    <Style Selector="Menu > MenuItem:pointerover /template/ Border#PART_LayoutRoot,
                     Menu > MenuItem:pressed /template/ Border#PART_LayoutRoot,
                     Menu > MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#3E3E42"/>
    </Style>

    <!-- Top-level Menu Item Text Interaction States -->
    <Style Selector="Menu > MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter,
                     Menu > MenuItem:pressed /template/ ContentPresenter#PART_HeaderPresenter,
                     Menu > MenuItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="TextBlock.Foreground" Value="#D1D1D1"/>
    </Style>

    <!-- Submenu Item Interaction States -->
    <Style Selector="MenuItem MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#E5E5E5"/>
    </Style>
</Window.Styles>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

<DockPanel>
    <!-- Top Menu Bar -->
    <Menu DockPanel.Dock="Top" Background="#2D2D2D" Name="MainMenu">
    </Menu>

    <!-- Main Content Area -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Activity Bar -->
            <ColumnDefinition Width="48"/>
            <!-- Editor Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Activity Bar (Left Icon Bar) -->
        <StackPanel Grid.Column="0" Background="#333333" Name="ActivityBar">
        </StackPanel>

        <!-- Main Content Area for User Customization -->
        <ContentControl Grid.Column="1" Name="MainContent" Background="#1E1E1E"/>
    </Grid>
</DockPanel>

</Window>
