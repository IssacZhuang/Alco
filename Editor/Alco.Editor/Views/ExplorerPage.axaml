<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:views="clr-namespace:Alco.Editor.Views"
    xmlns:vm="clr-namespace:Alco.Editor.ViewModels"
    d:DesignWidth="1200"
    d:DesignHeight="800"
    x:Class="Alco.Editor.Views.ExplorerPage">
    <Grid ColumnDefinitions="250,Auto,*">
        <!-- File browser area -->
        <Border Grid.Column="0"
            BorderBrush="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            BorderThickness="0,0,1,0">
            <Grid>
                <!-- Initial state - Open Folder button -->
                <StackPanel x:Name="NoFolderPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10">
                    <TextBlock Text="No folder opened"
                        HorizontalAlignment="Center" />
                    <Button x:Name="OpenFolderButton"
                        Content="Open Folder"
                        Click="OnOpenFolderClick" />
                </StackPanel>

                <!-- File tree view - initially hidden -->
                <views:FlatFileExplorer x:Name="FileTreeView"
                    IsVisible="False"
                />
            </Grid>
        </Border>

        <!-- Splitter between file browser and main area -->
        <GridSplitter Grid.Column="1"
            Background="{DynamicResource SystemControlHighlightBaseMediumLowBrush}"
            ResizeDirection="Columns"
            Width="4" />

        <!-- Main content area (combined edit and preview) -->
        <Border Grid.Column="2">
            <TabControl
                TabStripPlacement="Top"
                x:Name="DocumentTabs"
                Margin="0">
                <TabControl.Styles>
                    <!-- Enable multi-line tabs -->
                    <Style Selector="TabItem">
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="Padding" Value="8,4" />
                    </Style>
                </TabControl.Styles>
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>
                <TabControl.ItemTemplate>
                    <DataTemplate
                        DataType="vm:InspectorTabItem">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                            <!-- Tab text -->
                            <TextBlock Grid.Column="0"
                                Text="{Binding Filename}"
                                VerticalAlignment="Center" />

                            <!-- Unsaved indicator (white dot) with reserved space -->
                            <Border Grid.Column="1"
                                Width="13" Height="13"
                                Margin="5,0,0,0">
                                <Ellipse
                                    Width="8" Height="8"
                                    Fill="White"
                                    x:Name="UnsavedIndicator"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsModified}"
                                />
                            </Border>

                            <!-- Close button with reserved space -->
                            <Border Grid.Column="3"
                                Width="16" Height="16"
                                Margin="0,0,0,0">
                                <Button
                                    x:Name="BtnCloseTab"
                                    Width="16" Height="16"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnBtnCloseTabClick">
                                    <TextBlock Text="✕"
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center" />
                                </Button>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate
                        DataType="vm:InspectorTabItem">
                        <ContentControl Content="{Binding Content}" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Border>
    </Grid>
</UserControl> 