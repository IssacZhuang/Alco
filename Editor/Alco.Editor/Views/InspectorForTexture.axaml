<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:Alco.Editor.ViewModels"
  xmlns:views="using:Alco.Editor.Views"
  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
  x:DataType="vm:InspectorForTexture"
  x:Class="Alco.Editor.Views.InspectorForTexture">

  <Design.DataContext>
    <vm:InspectorForTexture />
  </Design.DataContext>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    
    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="15 10">
      <TextBlock x:Name="TextFilename" VerticalAlignment="Center" />
      <StackPanel Orientation="Horizontal" Margin="20 0 0 0">
        <TextBlock Text="Blend State:" VerticalAlignment="Center" Margin="0 0 5 0" />
        <ComboBox x:Name="BlendStateComboBox" Width="150" SelectionChanged="OnBlendStateChanged" />
      </StackPanel>
    </StackPanel>
    <views:TextureGPUSurfaceView x:Name="SurfaceView" Grid.Row="1" />
  </Grid>
</UserControl> 