<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PublishSingleFile>false</PublishSingleFile>

    <UseVulkan>true</UseVulkan>
    <UseWebGPU>true</UseWebGPU>

    <DefineConstants Condition="'$(UseVulkan)' == 'true'">$(DefineConstants);USE_VULKAN</DefineConstants>
    <DefineConstants Condition="'$(UseWebGPU)' == 'true'">$(DefineConstants);USE_WEBGPU</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Vulkan\**\*" Condition="'$(UseVulkan)' != 'true'" />
    <Compile Remove="WGPU\**\*" Condition="'$(UseWebGPU)' != 'true'" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Silk.NET.Shaderc" Version="2.20.0" />
    <PackageReference Include="Silk.NET.Shaderc.Native" Version="2.20.0" />
    <PackageReference Include="Silk.NET.SPIRV.Reflect" Version="2.20.0" />
    <PackageReference Include="Silk.NET.SPIRV.Reflect.Native" Version="2.20.0" />
    <PackageReference Include="SharpGen.Runtime" Version="2.1.2-beta" />
    <PackageReference Include="SharpGen.Runtime.COM" Version="2.1.2-beta" />

    <PackageReference Condition="'$(UseVulkan)' == 'true'" Include="Vortice.Vulkan" Version="1.8.5" />
    <PackageReference Condition="'$(UseWebGPU)' == 'true'" Include="Alimer.Bindings.WebGPU" Version="1.3.5" />
  </ItemGroup>
</Project>
