<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseAssetsPack>false</UseAssetsPack>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Vocore\Vocore.csproj" />
    <ProjectReference Include="..\Vocore.Graphics\Vocore.Graphics.csproj" />
    <ProjectReference Include="..\Vocore.ShaderCompiler\Vocore.ShaderCompiler.csproj" />
  </ItemGroup>
   <ItemGroup>
    <Content
      Condition="'$(UseAssetsPack)' == 'false'"
      Include="$(MSBuildThisFileDirectory)/Assets/**/*.*">
      <Link>Assets/%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
