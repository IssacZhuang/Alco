<Project>
  <PropertyGroup>
    <TempFolder>$([System.IO.Path]::GetTempPath())$([System.Guid]::NewGuid())</TempFolder>
  </PropertyGroup>

  <ItemGroup>
    <_CopyItems Include="$(OutputPath)\**\*.*" />
  </ItemGroup>

  <UsingTask TaskName="Vocore.Engine.Tool.AssetsBuildTask"
    AssemblyFile = "$(TempFolder)/Vocore.Engine.dll" />

  <!-- make tmp directory -->
  <Target Name="MakeTempFolder" AfterTargets="AfterBuild">
    <MakeDir Directories="$(TempFolder)" />
    <Copy SourceFiles="$(_CopyItems)" DestinationFiles="$(TempFolder)" />
    <AssetsBuildTask 
      AssetsDir = "$(ProjectDir)/../Assets"
      OutputDir = "$(TempFolder)"
      PackageName = "EngineAssets.vpk"
    />
  </Target>


  <!-- <ItemGroup>
    <Content Include="$(TempFolder)/EngineAssets.vpk">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup> -->
</Project>