<Project>
    <UsingTask TaskName="Vocore.Engine.Tool.AssetsBuildTask"
    AssemblyFile = "$(OutputPath)Vocore.Engine.dll" />

  <Target Name="InvokeCustomTask" AfterTargets="AfterBuild">
    <AssetsBuildTask 
      AssetsDir = "$(ProjectDir)Assets"
      OutputDir = "$(OutputPath)"
    />
  </Target>
</Project>