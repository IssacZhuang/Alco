<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Vocore.Engine</RootNamespace>
    <AssemblyName>Vocore.Engine</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishSingleFile>false</PublishSingleFile>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <UseGLFW>true</UseGLFW>
    <UseSDL>false</UseSDL>

    <UseAssetsPack>false</UseAssetsPack>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Vocore\Vocore.csproj" />
    <ProjectReference Include="..\Vocore.Graphics\Vocore.Graphics.csproj" />
    <ProjectReference Include="..\Vocore.Rendering\Vocore.Rendering.csproj" />
    <InternalsVisibleTo Include="$(AssemblyName).Test" />
  </ItemGroup>
  <ItemGroup>
     <PackageReference Include="System.IO.Hashing" Version="8.0.0">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Condition="'$(UseSDL)' == 'true'" Include="Silk.NET.Input.Sdl" Version="2.20.0" />
    <PackageReference Condition="'$(UseSDL)' == 'true'" Include="Silk.NET.Windowing.Sdl" Version="2.20.0" />
    <PackageReference Condition="'$(UseGLFW)' == 'true'" Include="Silk.NET.Input.Glfw" Version="2.20.0" />
    <PackageReference Condition="'$(UseGLFW)' == 'true'" Include="Silk.NET.Windowing.Glfw" Version="2.20.0" />
  </ItemGroup>


  <!-- Aseets Packer Task-->
  <ItemGroup>
    <PackageReference Include="Microsoft.Build" Version="17.9.5" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.9.5" />
  </ItemGroup>
  <PropertyGroup>
    <!-- tmp folder with uuid -->
    <TaskUUID>$([System.Guid]::NewGuid())</TaskUUID>
    <TempRoot>$(MSBuildProjectDirectory)/.tmp</TempRoot>
    <TempFolder>$(TempRoot)/$(TaskUUID)</TempFolder>
  </PropertyGroup>

  <!-- copy assets to output folder if UseAssetsPack is false -->
  <ItemGroup>
    <Content Condition="'$(UseAssetsPack)' == 'false'" Include="$(MSBuildThisFileDirectory)/Assets/**/*.*">
      <Link>Assets/%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <UsingTask Condition="'$(UseAssetsPack)' == 'true'" TaskName="Vocore.Engine.Tool.AssetsBuildTask" AssemblyFile="$(TempFolder)/Vocore.Engine.dll" />

  <Target Condition="'$(UseAssetsPack)' == 'true'" Name="PackEngineAssets" AfterTargets="AfterBuild">
    <ItemGroup>
      <CopyItems Include="$(OutputPath)\**\*.*" />
    </ItemGroup>
    <MakeDir Directories="$(TempFolder)" />
    <Copy SourceFiles="@(CopyItems)" DestinationFolder="$(TempFolder)" />
    <AssetsBuildTask AssetsDir="$(ProjectDir)/Assets" OutputDir="$(OutputPath)" PackageName="EngineAssets.vpk" />
  </Target>

  <ItemGroup>
    <Content Condition="'$(UseAssetsPack)' == 'true'" Include="$(OutputPath)EngineAssets.vpk">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Condition="'$(UseAssetsPack)' == 'true'" Include="Vocore.Engine.Assets.targets" Pack="true" PackagePath="build" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vocore.GUI\Vocore.GUI.csproj" />
  </ItemGroup>
</Project>