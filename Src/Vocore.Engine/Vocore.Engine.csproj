<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Vocore.Engine</RootNamespace>
    <AssemblyName>Vocore.Engine</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishSingleFile>false</PublishSingleFile>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <UseGLFW>true</UseGLFW>
    <UseSDL>false</UseSDL>

  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Vocore\Vocore.csproj" />
    <ProjectReference Include="..\Vocore.Audio\Vocore.Audio.csproj" />
    <ProjectReference Include="..\Vocore.Graphics\Vocore.Graphics.csproj" />
    <ProjectReference Include="..\Vocore.Rendering\Vocore.Rendering.csproj" />
    <ProjectReference Include="..\Vocore.GUI\Vocore.GUI.csproj" />
    <ProjectReference Include="..\Vocore.IO\Vocore.IO.csproj" />
    <InternalsVisibleTo Include="$(AssemblyName).Test" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Condition="'$(UseSDL)' == 'true'" Include="Silk.NET.Input.Sdl" Version="2.20.0" />
    <PackageReference Condition="'$(UseSDL)' == 'true'" Include="Silk.NET.Windowing.Sdl" Version="2.20.0" />
    <PackageReference Condition="'$(UseGLFW)' == 'true'" Include="Silk.NET.Input.Glfw" Version="2.20.0" />
    <PackageReference Condition="'$(UseGLFW)' == 'true'" Include="Silk.NET.Windowing.Glfw" Version="2.20.0" />
  </ItemGroup>

  <!-- Assets Compiler-->

  <PropertyGroup>
    <AssetsPath>$(MSBuildThisFileDirectory)Assets</AssetsPath>
  </PropertyGroup>
  <ItemGroup>
    <CompilerVisibleProperty Include="AssetsPath" />
    <ProjectReference Include="..\Vocore.Tool.AssetsCompiler\Vocore.Tool.AssetsCompiler.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
  </ItemGroup>

</Project>