<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Vocore.Engine</RootNamespace>
    <AssemblyName>Vocore.Engine</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishSingleFile>false</PublishSingleFile>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Vocore\Vocore.csproj" />
    <ProjectReference Include="..\Vocore.Graphics\Vocore.Graphics.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Silk.NET.Input.Glfw" Version="2.19.0" />
    <PackageReference Include="Silk.NET.Windowing.Glfw" Version="2.19.0" />
    <!-- <PackageReference Include="Silk.NET.Windowing.Extensions.Veldrid" Version="2.19.0" /> -->
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Assets\**">
      <LogicalName>%(EmbeddedResource.Identity)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>
</Project>